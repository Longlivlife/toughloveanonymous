# Tough Love Anonymous — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://phfrqscfjwtvnbsdaptf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Anthropic — server-side only, never expose to client
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─────────────────────────────────────────────────────────────
# SUPABASE SETUP CHECKLIST
# ─────────────────────────────────────────────────────────────
# 1. Authentication → URL Configuration:
#    Site URL: http://localhost:3000 (local) or https://toughloveanonymous.com (prod)
#    Redirect URLs: http://localhost:3000/auth/callback
#
# 2. Storage → Create bucket named "evidence"
#    Set to Private
#    Add RLS policy: allow authenticated users to insert/select their own files
#    Policy (INSERT): auth.uid()::text = (storage.foldername(name))[1]
#    Policy (SELECT): auth.uid()::text = (storage.foldername(name))[1]
#
# 3. Database → Run schema-v1.sql if not already done
# ─────────────────────────────────────────────────────────────
